{
  "name": "RemoteCodeIDE",
  "version": "0.1.0",
  "description": "Remote IDE desktop app with SSH/SFTP connections, Monaco editor, and integrated terminal. Similar to Codeanywhere and VS Code Remote SSH.",
  "author": "Ulisses Mantovani <mantovaniarts@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/minasvisual/remote-code-ide",
  "repository": {
    "type": "git",
    "url": "https://github.com/minasvisual/remote-code-ide.git"
  },
  "keywords": [
    "electron",
    "ssh",
    "sftp",
    "remote",
    "ide",
    "monaco",
    "editor",
    "developer-tools",
    "remote-development",
    "terminal"
  ],
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:console": "node scripts/dev.js --devtools",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "npm run build && playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "dependencies": {
    "chardet": "^2.0.0",
    "electron-store": "^8.2.0",
    "ssh2": "^1.15.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@codingame/monaco-editor-wrapper": "^29.0.0",
    "@codingame/monaco-languageclient": "^0.17.4",
    "@codingame/monaco-vscode-api": "^33.0.9",
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.11.19",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.8",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "monaco-editor": "^0.52.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.8",
    "vscode-ws-jsonrpc": "^3.5.0"
  },
  "build": {
    "appId": "com.mantovaniarts.remotecodeide",
    "productName": "Remote Code IDE",
    "icon": "resources/icons/icon",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icons/icon.ico",
      "sign": null
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icons/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icons/",
      "category": "Development"
    }
  }
}
