# Dependencies
node_modules/

# Build output (electron-vite → out/)
out/
dist/
dist-electron/

# Installer / packaged releases
release/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.pkg

# TypeScript build info
*.tsbuildinfo

# Vite cache
.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables & secrets
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.template

# SSH keys / certificates (never commit private keys)
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
*.csr
id_rsa
id_ed25519
id_ecdsa
id_dsa

# E2E test credentials (set via env vars: E2E_SSH_HOST, E2E_SSH_USER, E2E_SSH_PASS)
.env.test.local
.env.e2e
.env.e2e.*

# Playwright artifacts (test results, screenshots, reports, traces)
test-results/
playwright-report/
playwright/.cache/

# Vitest coverage
coverage/

# Claude Code local settings (machine-specific, may contain personal config)
.claude/settings.local.json

# OS artifacts
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.stackdump

# Editor / IDE artifacts
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# Temp files
*.tmp
*.temp
tmp/
temp/
